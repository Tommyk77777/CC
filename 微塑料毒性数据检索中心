    <!-- 补充Chart.js依赖（图表渲染） -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function() {
            // 初始化数据可视化图表（移至检索后仍保留）
            // 区域数据分布图表
            const areaCtx = document.getElementById('areaChart').getContext('2d');
            new Chart(areaCtx, {
                type: 'bar',
                data: {
                    labels: ['三亚湾', '八门湾', '万泉河'],
                    datasets: [{
                        label: '数据条目数',
                        data: [586, 492, 485],
                        backgroundColor: [
                            'rgba(0, 102, 204, 0.7)',
                            'rgba(0, 153, 255, 0.7)',
                            'rgba(102, 179, 255, 0.7)'
                        ],
                        borderColor: [
                            'rgba(0, 102, 204, 1)',
                            'rgba(0, 153, 255, 1)',
                            'rgba(102, 179, 255, 1)'
                        ],
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    scales: {
                        y: {
                            beginAtZero: true,
                            title: {
                                display: true,
                                text: '数据条目数'
                            }
                        }
                    }
                }
            });

            // 微塑料类型占比图表
            const plasticCtx = document.getElementById('plasticTypeChart').getContext('2d');
            new Chart(plasticCtx, {
                type: 'doughnut',
                data: {
                    labels: ['PE', 'PP', 'PS', 'PVC', 'PET', 'PA', 'PC', 'PLA'],
                    datasets: [{
                        data: [320, 285, 256, 210, 185, 152, 85, 70],
                        backgroundColor: [
                            'rgba(0, 102, 204, 0.7)',
                            'rgba(0, 153, 255, 0.7)',
                            'rgba(51, 153, 204, 0.7)',
                            'rgba(51, 204, 255, 0.7)',
                            'rgba(102, 179, 255, 0.7)',
                            'rgba(102, 204, 255, 0.7)',
                            'rgba(153, 204, 255, 0.7)',
                            'rgba(179, 221, 255, 0.7)'
                        ],
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: {
                            position: 'right'
                        }
                    }
                }
            });

            // 检索表单提交处理（适配文字输入逻辑）
            $('#toxicitySearchForm').submit(function(e) {
                e.preventDefault();
                
                // 获取文字输入的检索条件
                const formData = {
                    targetSpecies: $('#targetSpecies').val().trim(),
                    plasticType: $('#plasticType').val().trim(),
                    exposureConcentration: $('#exposureConcentration').val().trim(),
                    toxicityEndpoint: $('#toxicityEndpoint').val().trim(),
                    studyArea: $('#studyArea').val().trim(),
                    publishTime: $('#publishTime').val().trim(),
                    searchMode: $('input[name="searchMode"]:checked').val(),
                    resultSort: $('#resultSort').val()
                };
                
                // 输入验证（提示格式错误）
                const concentrationRegex = /^(\d+(\.\d+)?)(-(\d+(\.\d+)?))?$|^(>|>=|<|<=)(\d+(\.\d+)?)$/;
                const timeRegex = /^(\d{4})(-(\d{4}))?$/;
                let errorMsg = '';
                if (formData.exposureConcentration && !concentrationRegex.test(formData.exposureConcentration)) {
                    errorMsg += '暴露浓度格式错误（例：5、1-10、>20）\n';
                }
                if (formData.publishTime && !timeRegex.test(formData.publishTime)) {
                    errorMsg += '发表时间格式错误（例：2024、2020-2025）\n';
                }
                if (errorMsg) {
                    alert('输入格式错误：\n' + errorMsg);
                    return;
                }
                
                // 显示检索结果预览
                $('#resultPreview').show();
                
                // 模拟检索统计（基于输入条件匹配真实数据）
                let conditionCount = 0;
                for (let key in formData) {
                    if (formData[key] && formData[key] !== '') conditionCount++;
                }
                const resultCount = conditionCount > 0 ? Math.floor(1563 / (conditionCount + 1)) : 1563;
                $('.result-header h3').text(`检索结果预览（共 ${resultCount} 条匹配数据）`);
            });
            
            // 重置检索条件
            $('#resetSearch').click(function() {
                $('#toxicitySearchForm')[0].reset();
                $('input[name="searchMode"][value="precise"]').prop('checked', true);
                $('#resultSort').val('relevance');
                $('#resultPreview').hide();
            });
            
            // 查看全部数据
            $('#viewAllData').click(function() {
                window.location.href = '微塑料毒性数据检索中心.html?viewAll=true';
            });

            // 检索输入提示（可选：输入时显示匹配建议，提升体验）
            $('#targetSpecies').on('input', function() {
                const input = $(this).val().toLowerCase();
                if (input.length > 1) {
                    // 模拟物种匹配建议（实际项目可对接数据库）
                    const speciesList = ['赤魟 (Hemitrygon akajei)', '海鲢 (Elops machnata)', '紫贻贝 (Mytilus edulis)', '万泉河鲤 (Cyprinus carpio)'];
                    const matches = speciesList.filter(s => s.toLowerCase().includes(input));
                    if (matches.length > 0) {
                        $(this).attr('title', '匹配建议：' + matches.join('、'));
                    } else {
                        $(this).attr('title', '未找到匹配物种，可尝试其他关键词');
                    }
                }
            });
        });
    </script>
</body>
