    <!-- 主内容区 -->
    <main class="main-content">
        <!-- 平台介绍 -->
        <section class="platform-intro">
            <h1>海南三亚湾、八门湾、万泉河生物微塑料毒性数据库与检索服务平台</h1>
            <p>本平台基于三大区域128种生物、8类微塑料类型的1563条权威毒性实验数据搭建，覆盖急性毒性（96h-LC50）、慢性毒性、氧化应激等6类毒性终点，为科研工作者提供多维度、高精度的专属检索服务，实现"检索-溯源-验证"的全流程科研闭环。</p>
        </section>

        <!-- 核心检索区（移至可视化前，新增文字输入） -->
        <section class="search-section">
            <div class="search-header">
                <h2>微塑料毒性数据多维度检索</h2>
                <p>支持文字输入+下拉选择双模式，精准匹配1563条实验数据，快速定位目标研究数据</p>
            </div>

            <!-- 检索表单（核心项新增文字输入功能） -->
            <form id="toxicitySearchForm" class="search-form">
                <!-- 目标物种：文字输入（支持学名/俗名模糊检索） -->
                <div class="form-group">
                    <label for="targetSpecies">目标物种</label>
                    <input type="text" id="targetSpecies" class="form-control" placeholder="输入物种学名/俗名（例：赤魟、Mytilus edulis）">
                    <div class="input-hint">提示：支持模糊检索，可输入部分名称（如"贻贝"）</div>
                </div>
                <!-- 微塑料类型：文字输入+下拉选择（隐藏下拉，输入时匹配） -->
                <div class="form-group">
                    <label for="plasticType">微塑料类型</label>
                    <input type="text" id="plasticType" class="form-control" placeholder="输入类型名称/缩写（例：聚苯乙烯、PS）">
                    <div class="input-hint">提示：支持PE/PP/PS/PVC/PET/PA/PC/PLA 8类类型</div>
                </div>
                <!-- 暴露浓度：文字输入（支持区间/具体值） -->
                <div class="form-group">
                    <label for="exposureConcentration">暴露浓度 (mg/L)</label>
                    <input type="text" id="exposureConcentration" class="form-control" placeholder="输入具体值或区间（例：5、1-10）">
                    <div class="input-hint">提示：区间格式支持"0.1-1"，单值支持"5"或">20"</div>
                </div>
                <!-- 毒性终点：文字输入（支持关键词匹配） -->
                <div class="form-group">
                    <label for="toxicityEndpoint">毒性终点</label>
                    <input type="text" id="toxicityEndpoint" class="form-control" placeholder="输入终点关键词（例：急性毒性、氧化应激）">
                    <div class="input-hint">提示：支持急性毒性/慢性毒性/氧化应激/遗传毒性等6类终点</div>
                </div>
                <!-- 研究区域：文字输入（支持区域名称匹配） -->
                <div class="form-group">
                    <label for="studyArea">研究区域</label>
                    <input type="text" id="studyArea" class="form-control" placeholder="输入区域名称（例：三亚湾、万泉河）">
                    <div class="input-hint">提示：仅支持三亚湾、八门湾、万泉河三大区域</div>
                </div>
                <!-- 发表时间：文字输入（支持年份/区间） -->
                <div class="form-group">
                    <label for="publishTime">发表时间</label>
                    <input type="text" id="publishTime" class="form-control" placeholder="输入年份或区间（例：2024、2020-2025）">
                    <div class="input-hint">提示：区间格式支持"2015-2019"，单年份支持"2023"</div>
                </div>
            </form>

            <!-- 检索模式选择 -->
            <div class="search-mode">
                <div class="mode-option">
                    <input type="radio" id="preciseSearch" name="searchMode" value="precise" checked>
                    <label for="preciseSearch">精准检索（完全匹配关键词）</label>
                </div>
                <div class="mode-option">
                    <input type="radio" id="fuzzySearch" name="searchMode" value="fuzzy">
                    <label for="fuzzySearch">模糊检索（包含关键词）</label>
                </div>
                <div class="mode-option">
                    <input type="radio" id="combineSearch" name="searchMode" value="combine">
                    <label for="combineSearch">多条件组合检索</label>
                </div>
            </div>

            <!-- 排序选项 -->
            <div class="sort-options">
                <label for="resultSort">检索结果排序：</label>
                <select id="resultSort" class="sort-select">
                    <option value="relevance">按相关性</option>
                    <option value="publishTime">按发表时间（最新优先）</option>
                    <option value="concentration">按暴露浓度（低到高）</option>
                    <option value="authority">按数据权威度（期刊影响因子）</option>
                </select>
            </div>

            <!-- 操作按钮 -->
            <div class="btn-group">
                <button type="submit" class="btn-primary">开始检索</button>
                <button type="button" class="btn-secondary" id="resetSearch">重置检索条件</button>
                <button type="button" class="btn-secondary" id="viewAllData">查看全部数据</button>
            </div>

            <!-- 检索结果预览（基于实际数据） -->
            <div class="result-preview" id="resultPreview" style="display: none;">
                <div class="result-header">
                    <h3>检索结果预览（共 28 条匹配数据）</h3>
                    <a href="微塑料毒性数据检索中心.html" class="btn btn-sm btn-primary">查看完整结果</a>
                </div>
                <table class="result-table">
                    <thead>
                        <tr>
                            <th>目标物种</th>
                            <th>微塑料类型</th>
                            <th>暴露浓度</th>
                            <th>毒性终点</th>
                            <th>研究区域</th>
                            <th>数据来源</th>
                            <th>操作</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>紫贻贝 (Mytilus edulis)</td>
                            <td>PS（聚苯乙烯）</td>
                            <td>5 mg/L</td>
                            <td>氧化应激 (SOD: 23.5 U/mgprot)</td>
                            <td>三亚湾</td>
                            <td>环境科学学报, 2024</td>
                            <td><a href="#" class="view-details">查看详情</a></td>
                        </tr>
                        <tr>
                            <td>三疣梭子蟹 (Portunus trituberculatus)</td>
                            <td>PE（聚乙烯）</td>
                            <td>10 mg/L</td>
                            <td>急性毒性 (96h-LC50: 28.7 mg/L)</td>
                            <td>八门湾</td>
                            <td>海洋学报, 2025</td>
                            <td><a href="#" class="view-details">查看详情</a></td>
                        </tr>
                        <tr>
                            <td>万泉河鲤 (Cyprinus carpio)</td>
                            <td>PVC（聚氯乙烯）</td>
                            <td>2 mg/L</td>
                            <td>慢性毒性 (28d生长抑制率: 12.3%)</td>
                            <td>万泉河</td>
                            <td>中国环境科学, 2023</td>
                            <td><a href="#" class="view-details">查看详情</a></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </section>

        <!-- 数据概览区（移至检索后） -->
        <section class="data-overview">
            <div class="overview-header">
                <h2>平台数据资源概览</h2>
                <p>基于已收录的1563条微塑料毒性实验数据，涵盖三亚湾、八门湾、万泉河三大研究区域</p>
            </div>

            <!-- 数据统计卡片 -->
            <div class="overview-stats">
                <div class="stat-card">
                    <h3>总数据条目</h3>
                    <div class="stat-value">1,563</div>
                    <div class="stat-desc">条毒性实验数据</div>
                </div>
                <div class="stat-card">
                    <h3>覆盖物种数</h3>
                    <div class="stat-value">128</div>
                    <div class="stat-desc">种本土生物</div>
                </div>
                <div class="stat-card">
                    <h3>微塑料类型</h3>
                    <div class="stat-value">8</div>
                    <div class="stat-desc">类主流微塑料</div>
                </div>
                <div class="stat-card">
                    <h3>毒性终点</h3>
                    <div class="stat-value">6</div>
                    <div class="stat-desc">类毒理学指标</div>
                </div>
            </div>

            <!-- 数据可视化图表 -->
            <div class="chart-container">
                <div class="chart-box">
                    <h3>各区域数据分布</h3>
                    <canvas id="areaChart" height="250"></canvas>
                </div>
                <div class="chart-box">
                    <h3>微塑料类型占比</h3>
                    <canvas id="plasticTypeChart" height="250"></canvas>
                </div>
            </div>
        </section>

        <!-- 功能特点区 -->
        <section class="features-section">
            <div class="feature-card">
                <h3>
                    <svg viewBox="0 0 24 24">
                        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
                    </svg>
                    双模式检索体验
                </h3>
                <ul>
                    <li>所有检索项支持文字输入，灵活匹配关键词（如物种俗名、类型缩写）</li>
                    <li>提供输入提示与示例，降低检索门槛（如浓度区间格式"0.1-1"）</li>
                    <li>支持精准/模糊/组合三种检索模式，适配不同科研需求</li>
                </ul>
            </div>
            <div class="feature-card">
